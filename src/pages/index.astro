---
import PromoStrip from '../components/server/PromoStrip.astro';
import ProductGrid from '../components/svelte/ProductGrid.svelte';
import StoreLayout from '../layouts/StoreLayout.astro';
---

<StoreLayout
  title="Shopedia | UI Automation Testing Playground"
  description="Practice UI automation against a demo e-commerce storefront with search, login, cart, checkout, and resettable seeded data for repeatable testing."
>
  <main class="page-shell py-8 sm:py-10">
    <section class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="surface-panel overflow-hidden p-6 sm:p-8">
        <div class="inline-flex rounded-full bg-shopedia-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-shopedia-700">
          Persistent local storefront
        </div>
        <h1 class="mt-5 max-w-3xl text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">
          Demo storefront flows for UI automation testing.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
          Practice search, login, cart, checkout, and account flows against a seeded, repeatable e-commerce UI built for browser-based testing and automation practice.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#catalog" class="rounded-full bg-shopedia-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-shopedia-700">
            Browse catalog
          </a>
          <a href="/register" class="rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-shopedia-200 hover:text-shopedia-700">
            Create account
          </a>
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div class="rounded-3xl bg-slate-50 p-4">
            <p class="text-sm font-semibold text-slate-900">Demo auth</p>
            <p class="mt-1 text-sm text-slate-500">Register with a fake OTP, or use the seeded customer account for faster testing.</p>
          </div>
          <div class="rounded-3xl bg-slate-50 p-4">
            <p class="text-sm font-semibold text-slate-900">Cart + instant buy</p>
            <p class="mt-1 text-sm text-slate-500">Test both guest cart persistence and one-click checkout from the catalog grid.</p>
          </div>
          <div class="rounded-3xl bg-slate-50 p-4">
            <p class="text-sm font-semibold text-slate-900">Resettable state</p>
            <p class="mt-1 text-sm text-slate-500">Clear everything from settings and reseed the demo store for the next automation run.</p>
          </div>
        </div>
      </div>

      <div class="grid gap-6">
        <PromoStrip />

        <div class="surface-panel p-6">
          <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Seeded customer</p>
          <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950">Ready-to-use demo login</h2>
          <dl class="mt-5 grid gap-3 text-sm text-slate-600">
            <div class="rounded-2xl bg-slate-50 px-4 py-3">
              <dt class="font-semibold text-slate-900">Email</dt>
              <dd class="mt-1">customer@gghgh.dev</dd>
            </div>
            <div class="rounded-2xl bg-slate-50 px-4 py-3">
              <dt class="font-semibold text-slate-900">Password</dt>
              <dd class="mt-1">password123</dd>
            </div>
          </dl>
          <a href="/login" class="mt-6 inline-flex rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
            Use demo login
          </a>
        </div>
      </div>
    </section>

    <section id="catalog" class="mt-10 space-y-5">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Catalog</p>
          <h2 class="text-3xl font-black tracking-tight text-slate-950">Seeded products for fast UI flows</h2>
        </div>
        <p class="text-sm text-slate-500">
          Browsing full seeded storefront
        </p>
      </div>

      <ProductGrid client:load pageSize={8} />
    </section>
  </main>
</StoreLayout>
