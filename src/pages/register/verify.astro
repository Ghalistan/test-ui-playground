---
import RegisterOtpForm from '../../components/svelte/RegisterOtpForm.svelte';
import StoreLayout from '../../layouts/StoreLayout.astro';
---

<StoreLayout
  title="Verify Registration | Shopedia"
  description="Finish the Shopedia demo OTP verification flow and activate your persistent local account."
  noindex
>
  <main class="page-shell py-8 sm:py-10">
    <div class="mx-auto max-w-3xl space-y-6">
      <section class="surface-panel p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Step 2 of 2</p>
        <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-950">Verify your Shopedia account</h1>
        <p class="mt-2 text-sm text-slate-500">Use the demo OTP code <span class="font-semibold text-shopedia-700">123456</span> to complete registration for this playground.</p>
        <div class="mt-8">
          <RegisterOtpForm client:load />
        </div>
      </section>
    </div>
  </main>
</StoreLayout>
