---
import CheckoutView from '../components/svelte/CheckoutView.svelte';
import StoreLayout from '../layouts/StoreLayout.astro';
---

<StoreLayout
  title="Checkout | Shopedia"
  description="Place a cash order from your Shopedia cart or instant-buy flow."
  noindex
>
  <main class="page-shell py-8 sm:py-10">
    <div class="mb-6 space-y-2">
      <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Checkout</p>
      <h1 class="text-3xl font-black tracking-tight text-slate-950">Complete your cash order</h1>
    </div>
    <CheckoutView client:load />
  </main>
</StoreLayout>
