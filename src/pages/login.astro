---
import LoginForm from '../components/svelte/LoginForm.svelte';
import StoreLayout from '../layouts/StoreLayout.astro';

const next = Astro.url.searchParams.get('next') ?? '/';
---

<StoreLayout
  title="Login | Shopedia"
  description="Sign in to Shopedia to continue with cart, checkout, and purchase history flows."
  noindex
>
  <main class="page-shell py-8 sm:py-10">
    <div class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <section class="surface-panel p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Welcome back</p>
        <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-950">Login to Shopedia</h1>
        <p class="mt-2 text-sm text-slate-500">Persistent sessions are stored locally, so your cart and history stay available after refresh.</p>
        <div class="mt-8">
          <LoginForm client:load next={next} />
        </div>
      </section>

      <aside class="surface-panel p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Demo shortcut</p>
        <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950">Use the seeded customer</h2>
        <div class="mt-5 space-y-3 text-sm text-slate-600">
          <div class="rounded-2xl bg-slate-50 px-4 py-3">
            <p class="font-semibold text-slate-900">Email</p>
            <p class="mt-1">customer@gghgh.dev</p>
          </div>
          <div class="rounded-2xl bg-slate-50 px-4 py-3">
            <p class="font-semibold text-slate-900">Password</p>
            <p class="mt-1">password123</p>
          </div>
          <p>The login form is prefilled with these credentials so you can immediately test cart, checkout, and history flows.</p>
        </div>
      </aside>
    </div>
  </main>
</StoreLayout>
