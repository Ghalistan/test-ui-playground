---
import CartView from '../components/svelte/CartView.svelte';
import StoreLayout from '../layouts/StoreLayout.astro';
---

<StoreLayout
  title="Cart | Shopedia"
  description="Review your locally persisted Shopedia cart and continue to cash checkout."
  noindex
>
  <main class="page-shell py-8 sm:py-10">
    <div class="mb-6 space-y-2">
      <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Cart</p>
      <h1 class="text-3xl font-black tracking-tight text-slate-950">Review your Shopedia cart</h1>
    </div>
    <CartView client:load />
  </main>
</StoreLayout>
