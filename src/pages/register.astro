---
import RegisterForm from '../components/svelte/RegisterForm.svelte';
import StoreLayout from '../layouts/StoreLayout.astro';
---

<StoreLayout
  title="Register | Shopedia"
  description="Create a Shopedia account with a demo OTP flow and persist your storefront activity locally."
  noindex
>
  <main class="page-shell py-8 sm:py-10">
    <div class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <section class="surface-panel p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">New account</p>
        <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-950">Register for Shopedia</h1>
        <p class="mt-2 text-sm text-slate-500">Only email, full name, nickname, and password are required. Shipping details can wait until checkout.</p>
        <div class="mt-8">
          <RegisterForm client:load />
        </div>
      </section>

      <aside class="surface-panel p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">How it works</p>
        <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950">Two-step demo verification</h2>
        <ol class="mt-5 space-y-4 text-sm text-slate-600">
          <li class="rounded-2xl bg-slate-50 px-4 py-3">1. Submit your registration details.</li>
          <li class="rounded-2xl bg-slate-50 px-4 py-3">2. Enter the fake OTP on the next screen.</li>
          <li class="rounded-2xl bg-slate-50 px-4 py-3">3. The account is created locally and logged in immediately.</li>
        </ol>
      </aside>
    </div>
  </main>
</StoreLayout>
